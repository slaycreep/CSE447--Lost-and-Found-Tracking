# Email Configuration for 2FA OTP Verification
# Copy this to .env and fill in your actual values

# Gmail SMTP Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Optional: Other email providers
# SendGrid: MAIL_SERVER=smtp.sendgrid.net, MAIL_PORT=587, MAIL_USERNAME=apikey, MAIL_PASSWORD=SG.xxxx...
# Mailgun: MAIL_SERVER=smtp.mailgun.org, MAIL_PORT=587, MAIL_USERNAME=postmaster@..., MAIL_PASSWORD=...
# AWS SES: MAIL_SERVER=email-smtp.region.amazonaws.com, MAIL_PORT=587, MAIL_USERNAME=..., MAIL_PASSWORD=...

# Database Configuration (optional)
DATABASE_URL=sqlite:///lostandfound.db

# Flask Configuration
SECRET_KEY=your-secret-key-here
